{
  "name": "frontis",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/react.js",
      "types": "./dist/react.d.ts"
    }
  },
  "types": "./src/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "AGENTS.md",
    "llms.txt",
    "CONTRIBUTING.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "demo:dev": "bun run --cwd ./demo dev",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "bunx tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "npm:deploy": "bash ./scripts/publish-npm.sh",
    "size": "size-limit"
  },
  "keywords": [],
  "author": "https://github.com/jayf0x",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jayf0x/fluidity.git"
  },
  "bugs": {
    "url": "https://github.com/jayf0x/fluidity/issues"
  },
  "homepage": "https://jayf0x.github.io/fluidity",
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0",
    "leva": ">=0.9.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": false
    },
    "react-dom": {
      "optional": false
    },
    "leva": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/parser": "^8.0.0",
    "@babel/traverse": "^8.0.0",
    "@rollup/pluginutils": "^5.4.0",
    "@size-limit/file": "^11.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^26.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@webgpu/types": "^0.1.70",
    "byte-snap": "^1.0.5",
    "jsdom": "^29.1.1",
    "leva": "^0.10.1",
    "prettier": "^3.8.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "size-limit": "^11.0.0",
    "terser": "^5.48.0",
    "typescript": "^6.0.3",
    "unplugin": "^3.0.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "1 gb"
    }
  ],
  "dependencies": {
    "@types/react": "^19.2.17"
  }
}
